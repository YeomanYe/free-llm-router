OPEN_ROUTER_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_TOKEN=
GITHUB_TOKEN=
CEREBRAS_API_KEY=
# Sign up at open.bigmodel.cn (personal dev account) to get the free `glm-4-flash`
# tier. International z.ai keys typically ship without the free package attached.
BIG_MODEL_API_KEY=
Z_API_KEY=
# Workers AI-scoped tokens can't list `/accounts`, so set the account id explicitly.
# Only optional when the token also has `Account Settings: Read`.
CLOUDFLARE_ACCOUNT_ID=
# Token needs the `Account > Workers AI > Read` (or Edit) permission.
# Reusing a broad `CLOUDFLARE_API_TOKEN` also works if it includes that scope.
CLOUDFLARE_WORKER_AI_TOKEN=

# Backup keys are picked up automatically by appending a number:
#   OPEN_ROUTER_API_KEY2, OPEN_ROUTER_API_KEY3, ...
#   GOOGLE_API_KEY2, ...
# Each extra key becomes a fallback provider instance (name#2, name#3).
